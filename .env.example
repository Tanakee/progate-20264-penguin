# ─────────────────────────────────────────────
# .env.example
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
# .env は git にコミットしないでください（.gitignore 参照）。
# ─────────────────────────────────────────────

# ── AWS 認証情報 ──────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=ap-northeast-1

# ── S3 ───────────────────────────────────────
S3_BUCKET_NAME=first-penguin-bucket
S3_RAW_PREFIX=raw/         # 原画像（Rekognition分析用）
S3_COMPOSED_PREFIX=composed/  # 合成画像（記録用）

# ── AppSync ──────────────────────────────────
APPSYNC_ENDPOINT=https://xxxxxxxxxxxxxxxxxx.appsync-api.ap-northeast-1.amazonaws.com/graphql
APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxx

# ── Timestream ───────────────────────────────
TIMESTREAM_DATABASE=first-penguin-db
TIMESTREAM_TABLE=clap-events

# ── ローカル開発用 LocalStack ─────────────────
# ローカル開発時は以下を有効化し、AWS_ENDPOINT_URL を設定する
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# ── エッジ処理設定 ────────────────────────────
CAMERA_INDEX=0              # カメラデバイス番号（通常は0）
MIC_INDEX=0                 # マイクデバイス番号
CLAP_THRESHOLD_DB=60        # 拍手検知の音圧閾値（dB）
AR_DISPLAY_DURATION_SEC=10  # ARペンギン表示の継続秒数
